# ─────────────────────────────────────────────────────────────────────────────
# OPL Crew Mono — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM API Keys (at least one required) ──────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Backend Config ────────────────────────────────────────────────────────
CONFIG_FILE=./opl-ai-software-team/config.yaml
FLASK_ENV=production

# ── Ports ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
VALIDATOR_PORT=8180
JIRA_PORT=8081
CONNECTOR_PORT=8082

# ── Code Validator ────────────────────────────────────────────────────────
VALIDATOR_LOG_LEVEL=INFO

# ── Jira Connector ───────────────────────────────────────────────────────
JIRA_BACKEND=rest
JIRA_BASE_URL=http://jira:8080
JIRA_EMAIL=
JIRA_API_TOKEN=
# JIRA_USERNAME=
# JIRA_PASSWORD=
# JIRA_PERSONAL_ACCESS_TOKEN=
# JIRA_PROJECT_KEYS=PROJ,DEMO
# JIRA_TRIGGER_STATUS=Ready for Dev
# JIRA_WEBHOOK_SECRET=

# ── LLM for Jira Connector Classifier ────────────────────────────────────
# LLM_API_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# ── Ollama (optional, for local models) ───────────────────────────────────
# OLLAMA_BASE_URL=http://ollama:11434

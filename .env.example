# ─────────────────────────────────────────────────────────────────────────────
# OPL Crew Mono — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM / Red Hat MaaS (Required) ────────────────────────────────────────
LLM_API_KEY=
LLM_API_BASE_URL=https://litellm-prod.apps.maas.redhatworkshops.io
LLM_MODEL=deepseek-r1-distill-qwen-14b

# ── Backend Config ────────────────────────────────────────────────────────
CONFIG_FILE=./opl-ai-software-team/config.yaml
FLASK_ENV=production

# ── CORS (split frontend deployment) ─────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# Defaults to http://localhost:3000 when unset. Set to your production UI URL
# when frontend and backend run on different hosts.
# ── Dev Compose profiles (dev-compose.yml) ───────────────────────────────
# Services without a profile: validator, backend, frontend.
# Uncomment to always start optional stacks with plain `podman compose up -d`:
# COMPOSE_PROFILES=skills,jira

# ── Ports ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
VALIDATOR_PORT=8180
JIRA_PORT=8081
CONNECTOR_PORT=8082

# ── Code Validator ────────────────────────────────────────────────────────
VALIDATOR_LOG_LEVEL=INFO

# ── Jira Connector ───────────────────────────────────────────────────────
JIRA_BACKEND=rest
JIRA_BASE_URL=http://jira:8080
JIRA_EMAIL=
JIRA_API_TOKEN=
# JIRA_USERNAME=
# JIRA_PASSWORD=
# JIRA_PERSONAL_ACCESS_TOKEN=
# JIRA_PROJECT_KEYS=PROJ,DEMO
# JIRA_TRIGGER_STATUS=Ready for Dev
# JIRA_WEBHOOK_SECRET=

# ── Skills Service ──────────────────────────────────────────────────────
# Path to skills-service (Git submodule at mono repo root: ./skills-service).
# Dev compose runs from opl-ai-software-team/, so default is parent/skills-service.
SKILLS_SERVICE_DIR=../skills-service
# SKILLS_DIR=./skills
# FRAPPE_SKILLS_DIR=../1frappe_ecosystem/frappe-apps-manager/.cursor/skills
# SKILLS_PORT=8090

# ── GitHub integration (PR creation after import & iterate refinements) ──
# Personal access token with repo + pull_request scopes
# GITHUB_TOKEN=ghp_your_token_here
# Git commit author identity used when pushing refined code
# GITHUB_USER_NAME=Your Name
# GITHUB_USER_EMAIL=you@example.com

# ── Ollama (optional, for local models instead of MaaS) ──────────────────
# OLLAMA_BASE_URL=http://ollama:11434

# ── Keycloak / Auth ──────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180
AUTH_ENABLED=true
# KEYCLOAK_CONNECTOR_CLIENT_SECRET=connector-service-secret-12345

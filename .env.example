# ─────────────────────────────────────────────────────────────────────────────
# OPL Crew Mono — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Release Version ──────────────────────────────────────────────────────
# Image tag for backend + frontend. compose.yml defaults to "latest".
# Pin a release when needed, e.g. APP_VERSION=v2.4.0
APP_VERSION=latest

# ── LLM / Red Hat MaaS (Required) ────────────────────────────────────────
LLM_API_KEY=
LLM_API_BASE_URL=https://litellm-prod.apps.maas.redhatworkshops.io
# Per-agent models (installer.sh prompts for these; also written to config.yaml)
LLM_MODEL_MANAGER=deepseek-r1-distill-qwen-14b
LLM_MODEL_WORKER=qwen3-14b
LLM_MODEL_REVIEWER=qwen3-14b

# ── Backend Config ────────────────────────────────────────────────────────
CONFIG_FILE=./opl-ai-software-team/config.yaml
FLASK_ENV=production

# Tech-stack file manifest guard for file_writer + validation (backend)
# strict  — only registered tech_stack paths during remediation; strict file_manifest check
# relaxed — allow companion tests + on-disk sources during remediation (default)
# off     — no write-time allowlist during remediation; skip file_manifest validation
TECH_STACK_MANIFEST_GUARD=relaxed

# Parallel file-generation workers per lane (backend / frontend dev phases).
# Overrides generation.parallel_file_workers in config.yaml when set.
# Omit (or leave empty) to use the value from config.yaml (default: 3).
# Set to 1 for sequential / debug mode; 3-4 for typical MaaS endpoints.
# PARALLEL_FILE_WORKERS=3

# ── CORS (split frontend deployment) ─────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# compose.yml defaults to http://localhost:3100 (community stack frontend).
# CORS_ALLOWED_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
# ── Dev Compose profiles (dev-compose.yml) ───────────────────────────────
# Services without a profile: validator, backend, frontend.
# Uncomment to always start optional stacks with plain `podman compose up -d`:
# COMPOSE_PROFILES=skills,jira

# ── Ports (community compose.yml defaults — uncomment to override) ───────
# FRONTEND_PORT=3100
# BACKEND_PORT=8280
# VALIDATOR_PORT=8281
# KEYCLOAK_PORT=8380
# Issuer/authority must match KEYCLOAK_PORT (browser reaches Keycloak on this host port):
# KEYCLOAK_ISSUER_URL=http://localhost:8380/realms/opl-crew
# VITE_OIDC_AUTHORITY=http://localhost:8380/realms/opl-crew
# JIRA_PORT=8081
# CONNECTOR_PORT=8082

# ── Code Validator ────────────────────────────────────────────────────────
VALIDATOR_LOG_LEVEL=INFO

# ── Jira Connector ───────────────────────────────────────────────────────
JIRA_BACKEND=rest
JIRA_BASE_URL=http://jira:8080
JIRA_EMAIL=
JIRA_API_TOKEN=
# JIRA_USERNAME=
# JIRA_PASSWORD=
# JIRA_PERSONAL_ACCESS_TOKEN=
# JIRA_PROJECT_KEYS=PROJ,DEMO
# JIRA_TRIGGER_STATUS=Ready for Dev
# JIRA_WEBHOOK_SECRET=

# ── Skills Service ──────────────────────────────────────────────────────
# Path to skills-service (Git submodule at mono repo root: ./skills-service).
# Dev compose runs from opl_ai_mono root; default is ./skills-service.
SKILLS_SERVICE_DIR=./skills-service
# Backend proxy URL — use local container in dev (skills profile); remote MCP only for prod override
# SKILLS_SERVICE_URL=http://skills-service:8090
# SKILLS_DIR=./skills
# FRAPPE_SKILLS_DIR=../1frappe_ecosystem/frappe-apps-manager/.cursor/skills
# SKILLS_PORT=8090

# ── GitHub integration (PR creation after import & iterate refinements) ──
# Personal access token with repo + pull_request scopes
# GITHUB_TOKEN=ghp_your_token_here
# Git commit author identity used when pushing refined code
# GITHUB_USER_NAME=Your Name
# GITHUB_USER_EMAIL=you@example.com

# ── Ollama (optional, for local models instead of MaaS) ──────────────────
# OLLAMA_BASE_URL=http://ollama:11434

# ── Keycloak / Auth ──────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180
AUTH_ENABLED=true
# Set false for passwordless demo (installer.sh sets this automatically)
# VITE_AUTH_ENABLED=false
